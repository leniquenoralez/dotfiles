	"bul-container:centered": {
		"prefix": "bul-container:centered",
		"body": "<div class=\"container\">\r\n  <div class=\"notification\">\r\n    This container is <strong>centered</strong> on desktop.\r\n  </div>\r\n</div>",
		"description": "If you don't want to have a maximum width but want to keep the 20px margin on the left and right sides, add the is-fluid modifier",
		"scope": "text.html,javascript"
	},
	"bul-container:fluid": {
		"prefix": "bul-container:fluid",
		"body": "<div class=\"container is-fluid\">\r\n  <div class=\"notification\">\r\n    This container is <strong>fluid</strong>: it will have a 20px gap on either side, on any viewport size.\r\n  </div>\r\n</div>",
		"description": "If you don't want to have a maximum width but want to keep the 20px margin on the left and right sides, add the is-fluid modifier",
		"scope": "text.html,javascript"
	},
