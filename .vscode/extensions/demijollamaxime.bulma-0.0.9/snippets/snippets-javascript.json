{
	"bul-box": {
		"prefix": "bul-box",
		"body": "<div class=\"box\">\r\n  <article class=\"media\">\r\n    <div class=\"media-left\">\r\n      <figure class=\"image is-64x64\">\r\n        <img src=\"http://bulma.io/images/placeholders/128x128.png\" alt=\"Image\"/>\r\n      </figure>\r\n    </div>\r\n    <div class=\"media-content\">\r\n      <div class=\"content\">\r\n        <p>\r\n          <strong>John Smith</strong> <small>@johnsmith</small> <small>31m</small>\r\n          <br/>\r\n          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aenean efficitur sit amet massa fringilla egestas. Nullam condimentum luctus turpis.\r\n        </p>\r\n      </div>\r\n      <nav class=\"level is-mobile\">\r\n        <div class=\"level-left\">\r\n          <a class=\"level-item\">\r\n            <span class=\"icon is-small\"><i class=\"fa fa-reply\"></i></span>\r\n          </a>\r\n          <a class=\"level-item\">\r\n            <span class=\"icon is-small\"><i class=\"fa fa-retweet\"></i></span>\r\n          </a>\r\n          <a class=\"level-item\">\r\n            <span class=\"icon is-small\"><i class=\"fa fa-heart\"></i></span>\r\n          </a>\r\n        </div>\r\n      </nav>\r\n    </div>\r\n  </article>\r\n</div>",
		"description": "A white box to contain other elements",
		"scope": "text.html,javascript"
	},
	"bul-buttons:disabled": {
		"prefix": "bul-buttons:disabled",
		"body": "\r\n<a class=\"button\" title=\"Disabled button\" disabled>Disabled</a>\r\n<a class=\"button is-primary\" title=\"Disabled button\" disabled>Disabled</a>\r\n<a class=\"button is-info\" title=\"Disabled button\" disabled>Disabled</a>\r\n<a class=\"button is-success\" title=\"Disabled button\" disabled>Disabled</a>\r\n<a class=\"button is-warning\" title=\"Disabled button\" disabled>Disabled</a>\r\n<a class=\"button is-danger\" title=\"Disabled button\" disabled>Disabled</a>",
		"description": "The classic button, in different colors, sizes, and states - Disabled",
		"scope": "text.html,javascript"
	},
	"bul-buttons:font-awesome-icons": {
		"prefix": "bul-buttons:font-awesome-icons",
		"body": "<p class=\"field\">\r\n  <a class=\"button\">\r\n    <span class=\"icon is-small\">\r\n      <i class=\"fa fa-bold\"></i>\r\n    </span>\r\n  </a>\r\n  <a class=\"button\">\r\n    <span class=\"icon is-small\">\r\n      <i class=\"fa fa-italic\"></i>\r\n    </span>\r\n  </a>\r\n  <a class=\"button\">\r\n    <span class=\"icon is-small\">\r\n      <i class=\"fa fa-underline\"></i>\r\n    </span>\r\n  </a>\r\n</p>\r\n<p class=\"field\">\r\n  <a class=\"button\">\r\n    <span class=\"icon\">\r\n      <i class=\"fa fa-github\"></i>\r\n    </span>\r\n    <span>GitHub</span>\r\n  </a>\r\n  <a class=\"button is-primary\">\r\n    <span class=\"icon\">\r\n      <i class=\"fa fa-twitter\"></i>\r\n    </span>\r\n    <span>Twitter</span>\r\n  </a>\r\n  <a class=\"button is-success\">\r\n\t",
		"description": "The classic button, in different colors, sizes, and states- With Font Awesome icons",
		"scope": "text.html,javascript"
	},
	"bul-buttons-group": {
		"prefix": "bul-buttons-group",
		"body": "<div class=\"field is-grouped\">\r\n  <p class=\"control\">\r\n    <a class=\"button is-primary\">\r\n      Save changes\r\n    </a>\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button\">\r\n      Cancel\r\n    </a>\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button is-danger\">\r\n      Delete post\r\n    </a>\r\n  </p>\r\n</div>",
		"description": "If you want to group buttons together, use the is-grouped modifier on the field container",
		"scope": "text.html,javascript"
	},
	"bul-buttons:inverted": {
		"prefix": "bul-buttons:inverted",
		"body": "<a class=\"button is-primary is-inverted\">Inverted</a>\r\n<a class=\"button is-info is-inverted\">Inverted</a>\r\n<a class=\"button is-success is-inverted\">Inverted</a>\r\n<a class=\"button is-danger is-inverted\">Inverted</a>",
		"description": "Inverted (the text color becomes the background color, and vice-versa)",
		"scope": "text.html,javascript"
	},
	"bul-buttons:loading": {
		"prefix": "bul-buttons:loading",
		"body": "<a class=\"button is-loading\">Loading</a>\r\n<a class=\"button is-primary is-loading\">Loading</a>\r\n<a class=\"button is-info is-loading\">Loading</a>\r\n<a class=\"button is-success is-loading\">Loading</a>\r\n<a class=\"button is-warning is-loading\">Loading</a>\r\n<a class=\"button is-danger is-loading\">Loading</a>",
		"description": "Loading buttons",
		"scope": "text.html,javascript"
	},
