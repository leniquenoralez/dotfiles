	"bul-footer": {
		"prefix": "bul-footer",
		"body": "<footer class=\"footer\">\r\n  <div class=\"container\">\r\n    <div class=\"content has-text-centered\">\r\n      <p>\r\n        <strong>Bulma</strong> by <a href=\"http://jgthms.com\">Jeremy Thomas</a>. The source code is licensed\r\n        <a href=\"http://opensource.org/licenses/mit-license.php\">MIT</a>. The website content\r\n        is licensed <a href=\"http://creativecommons.org/licenses/by-nc-sa/4.0/\">CC ANS 4.0</a>.\r\n      </p>\r\n      <p>\r\n        <a class=\"icon\" href=\"https://github.com/jgthms/bulma\">\r\n          <i class=\"fa fa-github\"></i>\r\n        </a>\r\n      </p>\r\n    </div>\r\n  </div>\r\n</footer>",
		"description": "A simple responsive footer which can include anything: lists, headings, columns, icons, buttons...",
		"scope": "text.html,javascript"
	},
	"bul-form:addons-select": {
		"prefix": "bul-form:addons-select",
		"body": "<div class=\"field has-addons\">\r\n  <p class=\"control\">\r\n    <span class=\"select\">\r\n      <select>\r\n        <option>$</option>\r\n        <option>£</option>\r\n        <option>€</option>\r\n      </select>\r\n    </span>\r\n  </p>\r\n  <p class=\"control\">\r\n    <input class=\"input\" type=\"text\" placeholder=\"Amount of money\">\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button\">\r\n      Transfer\r\n    </a>\r\n  </p>\r\n</div>\r\n<div class=\"field has-addons\">\r\n  <p class=\"control\">\r\n    <span class=\"select\">\r\n      <select>\r\n        <option>$</option>\r\n        <option>£</option>\r\n        <option>€</option>\r\n      </select>\r\n    </span>\r\n  </p>\r\n  <p class=\"control is-expanded\">\r\n    <input class=\"input\" type=\"text\" placeholder=\"Amount of money\">\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button\">\r\n      Transfer\r\n    </a>\r\n  </p>\r\n</div>",
		"description": "If you want a full width select dropdown, pair control is-expanded with select is-fullwidth",
		"scope": "text.html,javascript"
	},
	"bul-form:addons": {
		"prefix": "bul-form:addons",
		"body": "<div class=\"field has-addons\">\r\n  <p class=\"control\">\r\n    <input class=\"input\" type=\"text\" placeholder=\"Find a repository\">\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button is-info\">\r\n      Search\r\n    </a>\r\n  </p>\r\n</div>",
		"description": "If you want to attach controls together, use the has-addons modifier on the control container",
		"scope": "text.html,javascript"
	},
	"bul-form:controls": {
		"prefix": "bul-form:controls",
		"body": "<div class=\"field\">\r\n  <label class=\"label\">Name</label>\r\n  <p class=\"control\">\r\n    <input class=\"input\" type=\"text\" placeholder=\"Text input\">\r\n  </p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <label class=\"label\">Username</label>\r\n  <p class=\"control has-icon has-icon-right\">\r\n    <input class=\"input is-success\" type=\"text\" placeholder=\"Text input\" value=\"bulma\">\r\n    <span class=\"icon is-small\">\r\n      <i class=\"fa fa-check\"></i>\r\n    </span>\r\n  </p>\r\n  <p class=\"help is-success\">This username is available</p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <label class=\"label\">Email</label>\r\n  <p class=\"control has-icon has-icon-right\">\r\n    <input class=\"input is-danger\" type=\"text\" placeholder=\"Email input\" value=\"hello@\">\r\n    <span class=\"icon is-small\">\r\n      <i class=\"fa fa-warning\"></i>\r\n    </span>\r\n  </p>\r\n  <p class=\"help is-danger\">This email is invalid</p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <label class=\"label\">Subject</label>\r\n  <p class=\"control\">\r\n    <span class=\"select\">\r\n      <select>\r\n        <option>Select dropdown</option>\r\n        <option>With options</option>\r\n      </select>\r\n    </span>\r\n  </p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <label class=\"label\">Message</label>\r\n  <p class=\"control\">\r\n    <textarea class=\"textarea\" placeholder=\"Textarea\"></textarea>\r\n  </p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <p class=\"control\">\r\n    <label class=\"checkbox\">\r\n      <input type=\"checkbox\">\r\n      Remember me\r\n    </label>\r\n  </p>\r\n</div>\r\n\r\n<div class=\"field\">\r\n  <p class=\"control\">\r\n    <label class=\"radio\">\r\n      <input type=\"radio\" name=\"question\">\r\n      Yes\r\n    </label>\r\n    <label class=\"radio\">\r\n      <input type=\"radio\" name=\"question\">\r\n      No\r\n    </label>\r\n  </p>\r\n</div>\r\n\r\n<div class=\"field is-grouped\">\r\n  <p class=\"control\">\r\n    <button class=\"button is-primary\">Submit</button>\r\n  </p>\r\n  <p class=\"control\">\r\n    <button class=\"button is-link\">Cancel</button>\r\n  </p>\r\n</div>",
		"description": "All generic form controls, designed for consistency",
		"scope": "text.html,javascript"
	},
	"bul-form:group": {
		"prefix": "bul-form:group",
		"body": "<div class=\"field is-grouped\">\r\n  <p class=\"control is-expanded\">\r\n    <input class=\"input\" type=\"text\" placeholder=\"Find a repository\">\r\n  </p>\r\n  <p class=\"control\">\r\n    <a class=\"button is-info\">\r\n      Search\r\n    </a>\r\n  </p>\r\n</div>",
		"description": "If you want to group controls together, use the is-grouped modifier on the control container.",
		"scope": "text.html,javascript"
	},
	"bul-grid:columns-gapless": {
		"prefix": "bul-grid:columns-gapless",
		"body": "<div class=\"columns is-gapless\">\r\n\t<div class=\"column\">First column</div>\r\n \t<div class=\"column\">Second column</div>\r\n \t<div class=\"column\">Third column</div>\r\n \t<div class=\"column\">Fourth column</div>\r\n</div>",
		"description": "If you want to remove the space between the columns, add the is-gapless modifier on the columns container",
		"scope": "text.html,javascript"
	},
	"bul-grid:columns": {
		"prefix": "bul-grid:columns",
		"body": "<div class=\"columns\">\r\n  <div class=\"column\">\r\n    First column\r\n  </div>\r\n  <div class=\"column\">\r\n    Second column\r\n  </div>\r\n  <div class=\"column\">\r\n    Third column\r\n  </div>\r\n  <div class=\"column\">\r\n    Fourth column\r\n  </div>\r\n</div>",
		"description": "A simple way to build responsive columns",
		"scope": "text.html,javascript"
	},
	"bul-hero": {
		"prefix": "bul-hero",
		"body": "<section class=\"hero\">\r\n  <div class=\"hero-body\">\r\n    <div class=\"container\">\r\n      <h1 class=\"title\">\r\n        Hero title\r\n      </h1>\r\n      <h2 class=\"subtitle\">\r\n        Hero subtitle\r\n      </h2>\r\n    </div>\r\n  </div>\r\n</section>",
		"description": "An imposing hero banner to showcase something",
		"scope": "text.html,javascript"
	},
	"bul:html": {
		"prefix": "bul:html",
		"body": "<!DOCTYPE html>\r\n<html lang=\"\">\r\n    <head>\r\n        <meta charset=\"utf-8\">\r\n        <meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">\r\n        <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\r\n        <title>Title Page</title>\r\n        <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/bulma/0.4.0/css/bulma.css\"/>\r\n    </head>\r\n    <body>\r\n    </body>\r\n</html>",
		"description": "A bulma html 5 page",
		"scope": "text.html,javascript"
	},
	"bul-level:centered": {
		"prefix": "bul-level:centered",
		"body": "<nav class=\"level\">\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Tweets</p>\r\n      <p class=\"title\">3,456</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Following</p>\r\n      <p class=\"title\">123</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Followers</p>\r\n      <p class=\"title\">456K</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Likes</p>\r\n      <p class=\"title\">789</p>\r\n    </div>\r\n  </div>\r\n</nav>",
		"description": "If you want a centered level, you can use as many level-item as you want, as long as they are direct children of the level container",
		"scope": "text.html,javascript"
	},
	"bul-level:mobile": {
		"prefix": "bul-level:mobile",
		"body": "<nav class=\"level is-mobile\">\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Tweets</p>\r\n      <p class=\"title\">3,456</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Following</p>\r\n      <p class=\"title\">123</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Followers</p>\r\n      <p class=\"title\">456K</p>\r\n    </div>\r\n  </div>\r\n  <div class=\"level-item has-text-centered\">\r\n    <div>\r\n      <p class=\"heading\">Likes</p>\r\n      <p class=\"title\">789</p>\r\n    </div>\r\n  </div>\r\n</nav>",
		"description": "By default, for space concerns, the level is vertical on mobile. If you want the level to be horizontal on mobile as well, add the is-mobile modifier on the level container.",
		"scope": "text.html,javascript"
	},
	"bul-level": {
		"prefix": "bul-level",
		"body": "<!-- Main container -->\r\n<nav class=\"level\">\r\n  <!-- Left side -->\r\n  <div class=\"level-left\">\r\n    <div class=\"level-item\">\r\n      <p class=\"subtitle is-5\">\r\n        <strong>123</strong> posts\r\n      </p>\r\n    </div>\r\n    <div class=\"level-item\">\r\n      <div class=\"field has-addons\">\r\n        <p class=\"control\">\r\n          <input class=\"input\" type=\"text\" placeholder=\"Find a post\">\r\n        </p>\r\n        <p class=\"control\">\r\n          <button class=\"button\">\r\n            Search\r\n          </button>\r\n        </p>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- Right side -->\r\n  <div class=\"level-right\">\r\n    <p class=\"level-item\"><strong>All</strong></p>\r\n    <p class=\"level-item\"><a>Published</a></p>\r\n    <p class=\"level-item\"><a>Drafts</a></p>\r\n    <p class=\"level-item\"><a>Deleted</a></p>\r\n    <p class=\"level-item\"><a class=\"button is-success\">New</a></p>\r\n  </div>\r\n</nav>",
		"description": "A multi-purpose horizontal level, which can contain almost any other element",
		"scope": "text.html,javascript"
	},
	"bul-menu": {
		"prefix": "bul-menu",
		"body": "<aside class=\"menu\">\r\n  <p class=\"menu-label\">\r\n    General\r\n  </p>\r\n  <ul class=\"menu-list\">\r\n    <li><a>Dashboard</a></li>\r\n    <li><a>Customers</a></li>\r\n  </ul>\r\n  <p class=\"menu-label\">\r\n    Administration\r\n  </p>\r\n  <ul class=\"menu-list\">\r\n    <li><a>Team Settings</a></li>\r\n    <li>\r\n      <a class=\"is-active\">Manage Your Team</a>\r\n      <ul>\r\n        <li><a>Members</a></li>\r\n        <li><a>Plugins</a></li>\r\n        <li><a>Add a member</a></li>\r\n      </ul>\r\n    </li>\r\n    <li><a>Invitations</a></li>\r\n    <li><a>Cloud Storage Environment Settings</a></li>\r\n    <li><a>Authentication</a></li>\r\n  </ul>\r\n  <p class=\"menu-label\">\r\n    Transactions\r\n  </p>\r\n  <ul class=\"menu-list\">\r\n    <li><a>Payments</a></li>\r\n    <li><a>Transfers</a></li>\r\n    <li><a>Balance</a></li>\r\n  </ul>\r\n</aside>",
		"description": "A simple menu, for any type of vertical navigation",
		"scope": "text.html,javascript"
	},
