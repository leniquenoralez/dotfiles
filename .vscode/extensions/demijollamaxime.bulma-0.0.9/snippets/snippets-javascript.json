		"description": "Buttons sizes outlined",
		"scope": "text.html,javascript"
	},
	"bul-buttons": {
		"prefix": "bul-buttons",
		"body": "<div class=\"block\">\r\n  <a class=\"button\">Button</a>\r\n  <a class=\"button is-white\">White</a>\r\n  <a class=\"button is-light\">Light</a>\r\n  <a class=\"button is-dark\">Dark</a>\r\n  <a class=\"button is-black\">Black</a>\r\n  <a class=\"button is-link\">Link</a>\r\n</div>\r\n<div class=\"block\">\r\n  <a class=\"button is-primary\">Primary</a>\r\n  <a class=\"button is-info\">Info</a>\r\n  <a class=\"button is-success\">Success</a>\r\n  <a class=\"button is-warning\">Warning</a>\r\n  <a class=\"button is-danger\">Danger</a>\r\n</div>",
		"description": "The classic button, in different colors, sizes, and states",
		"scope": "text.html,javascript"
	},
	"bul-card": {
		"prefix": "bul-card",
		"body": "<div class=\"card\">\r\n  <div class=\"card-image\">\r\n    <figure class=\"image is-4by3\">\r\n      <img src=\"http://bulma.io/images/placeholders/1280x960.png\" alt=\"Image\"/>\r\n    </figure>\r\n  </div>\r\n  <div class=\"card-content\">\r\n    <div class=\"media\">\r\n      <div class=\"media-left\">\r\n        <figure class=\"image is-48x48\">\r\n          <img src=\"http://bulma.io/images/placeholders/96x96.png\" alt=\"Image\"/>\r\n        </figure>\r\n      </div>\r\n      <div class=\"media-content\">\r\n        <p class=\"title is-4\">John Smith</p>\r\n        <p class=\"subtitle is-6\">@johnsmith</p>\r\n      </div>\r\n    </div>\r\n\r\n    <div class=\"content\">\r\n      Lorem ipsum dolor sit amet, consectetur adipiscing elit.\r\n      Phasellus nec iaculis mauris. <a>@bulmaio</a>.\r\n      <a>#css</a> <a>#responsive</a>\r\n      <br/>\r\n      <small>11:09 PM - 1 Jan 2016</small>\r\n    </div>\r\n  </div>\r\n</div>",
		"description": "An all-around flexible and composable component",
		"scope": "text.html,javascript"
	},
